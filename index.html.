<style>
  :root {
    --black: #0a0a0a;
    --ink: #141414;
    --yellow: #ffd400;
    --yellow-hot: #ffe500;
    --shadow: #000000;
    --white: #f7f5f0;
    --grey: #2a2a2a;
    --grey-2: #1a1a1a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 500;
    font-weight: 500;
    line-height: 1.5;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  .mono { font-family: 'Frank Ruhl Libre', serif; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

  /* ---------- NAV ---------- */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: #000000;
    border-bottom: 1px solid rgba(255,212,0,0.15);
  }
  nav .container { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; }
  .logo { display: flex; align-items: center; text-decoration: none; }
  .logo img { height: 60px; width: auto; display: block; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3)); }
  @media (max-width: 600px) { .logo img { height: 46px; } }
  .nav-cta {
    background: var(--yellow); color: var(--black); padding: 10px 18px;
    text-decoration: none; font-weight: 800; font-size: 13px; text-transform: uppercase;
    border: 2px solid var(--black); transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 4px 4px 0 var(--shadow);
  }
  .nav-cta:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--shadow); }

  /* ---------- HERO ---------- */
  .hero {
    min-height: 100vh; padding: 140px 0 80px;
    position: relative; overflow: hidden;
    background: #000000;
  }

  .hero-grid {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
    align-items: center;
  }

  .badge {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--yellow); color: var(--black);
    padding: 8px 16px; font-family: 'Frank Ruhl Libre', serif;
    font-size: 12px; font-weight: 700; text-transform: uppercase;
    margin-bottom: 28px;
  }
  .badge .dot { width: 8px; height: 8px; background: var(--white); border-radius: 50%; animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  h1.hero-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(48px, 7.5vw, 110px);
    line-height: 0.88; text-transform: uppercase; letter-spacing: 0;
    margin-bottom: 28px;
  }
  h1 .accent { color: var(--yellow); display: inline-block; position: relative; }
  h1 .accent::after {
    content: ""; position: absolute; left: -4px; right: -4px; bottom: 8px; height: 14px;
    background: var(--yellow); z-index: -1; transform: skew(-12deg);
  }
  h1 .strike { display: inline-block; transform: rotate(-2deg); background: var(--white); color: var(--black); padding: 0 12px; }

  .hero-logo {
    margin-bottom: 32px;
    max-width: 420px;
    position: relative;
  }
  .hero-logo img {
    position: relative;
    z-index: 1;
    width: 100%; height: auto; display: block;
    filter: drop-shadow(0 6px 16px rgba(0,0,0,0.6));
    transform: rotate(-2deg);
    transition: transform 0.4s ease;
  }
  .hero-logo img:hover { transform: rotate(0deg) scale(1.02); }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .hero-sub {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(32px, 4.2vw, 60px);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--white);
    max-width: 620px;
    margin-bottom: 44px;
  }
  .hero-sub .y { color: var(--yellow); }

  .cta-row { display: flex; flex-wrap: wrap; gap: 16px; }
  .btn {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 18px 28px; font-weight: 800; font-size: 15px;
    text-transform: uppercase; text-decoration: none;
    border: 3px solid var(--black); transition: all 0.2s;
    font-family: 'Frank Ruhl Libre', serif; letter-spacing: 0.02em;
  }
  .btn-primary { background: var(--yellow); color: var(--black); box-shadow: 6px 6px 0 var(--shadow); }
  .btn-primary:hover { transform: translate(-3px,-3px); box-shadow: 9px 9px 0 var(--shadow); }
  .btn-secondary { background: var(--white); color: var(--black); box-shadow: 6px 6px 0 var(--shadow); }
  .btn-secondary:hover { transform: translate(-3px,-3px); box-shadow: 9px 9px 0 var(--shadow); }
  .btn svg { width: 20px; height: 20px; }

  /* Hero card / phone visual */
  .hero-card {
    position: relative; aspect-ratio: 4/5;
    background: linear-gradient(160deg, var(--yellow) 0%, var(--yellow-hot) 100%);
    border: 4px solid var(--black);
    box-shadow: 16px 16px 0 var(--shadow), 16px 16px 0 4px var(--black);
    padding: 40px 32px; transform: rotate(2deg);
    color: var(--black); display: flex; flex-direction: column; justify-content: center; gap: 32px;
  }
  .hero-card .corner-stamp {
    position: absolute; top: -20px; left: -20px;
    background: var(--yellow); color: var(--black);
    width: 90px; height: 90px; border-radius: 50%;
    border: 4px solid var(--black);
    display: grid; place-items: center; text-align: center;
    font-family: 'Frank Ruhl Libre', serif; font-size: 11px;
    line-height: 1.1; padding: 10px;
    transform: rotate(-15deg);
  }
  .hero-card-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .hero-card-top .mono { font-size: 11px; font-weight: 700; }
  .hero-card-mid {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0;
    word-spacing: 0.02em;
  }
  .hero-card-mid .mid-accent {
    color: var(--black);
    
  }
  .hero-card-bottom { border-top: 3px solid var(--black); padding-top: 16px; }
  .hero-card-bottom .mono { font-size: 10px; opacity: 0.7; }
  .hero-card-bottom .num { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 24px; }

  /* truck illustration */
  .truck {
    position: absolute; bottom: 30px; left: 30px; right: 30px; height: 60px;
    opacity: 0.85;
  }

  /* ---------- SECTIONS ---------- */
  section { padding: 110px 0; position: relative; }
  .section-label {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 12px; text-transform: uppercase; letter-spacing: 0.2em;
    color: var(--yellow); margin-bottom: 20px; font-weight: 700;
  }
  .section-label::before { content: ""; width: 30px; height: 2px; background: var(--yellow); }
  .section-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(38px, 5vw, 76px);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    margin-bottom: 24px;
    max-width: 900px;
  }
  .section-title .y { color: var(--yellow); }
  .section-intro {
    font-size: clamp(15px, 1.3vw, 18px);
    color: rgba(247,245,240,0.7);
    max-width: 600px;
    margin-bottom: 64px;
    line-height: 1.6;
  }

  /* ---------- SERVICES (Tetris style) ---------- */
  .services { background: var(--ink); }
  .services-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .service-card {
    padding: 28px 24px 64px;
    position: relative;
    cursor: pointer; overflow: hidden;
    background: var(--black);
    border: 3px solid var(--grey);
    transition: border-color 0.3s, transform 0.3s;
    user-select: none;
    display: flex;
    flex-direction: column;
    min-height: 240px;
  }
  .service-card .click-hint {
    position: absolute; bottom: 16px; right: 16px;
    width: 36px; height: 36px;
    background: var(--yellow); color: var(--black);
    display: grid; place-items: center;
    font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 18px;
    opacity: 0; transform: translateY(8px) scale(0.8);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 2;
  }
  .service-card:hover .click-hint {
    opacity: 1; transform: translateY(0) scale(1);
  }
  .service-card:active { transform: scale(0.98); }
  /* Tetris pixel grid background — appears on hover */
  .service-card::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,212,0,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,212,0,0.06) 1px, transparent 1px);
    background-size: 12px 12px;
    opacity: 0; transition: opacity 0.4s;
    pointer-events: none;
  }
  .service-card:hover::before { opacity: 1; }

  /* Tetris block accent — falls down on hover */
  .service-card::after {
    content: "";
    position: absolute; top: 0; left: 0; width: 100%; height: 4px;
    background: var(--yellow);
    transform: translateY(-100%);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .service-card:hover::after { transform: translateY(0); }

  .service-card:hover {
    border-color: var(--yellow);
    transform: translateY(-4px);
  }

  /* Floating tetris pieces on hover */
  .tetris-pieces {
    position: absolute; top: 12px; right: 12px; width: 48px; height: 48px;
    opacity: 0; transform: translateY(-30px) rotate(-45deg) scale(0.5);
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }
  .service-card:hover .tetris-pieces {
    opacity: 0.6; transform: translateY(0) rotate(0deg) scale(1);
  }

  .service-num {
    font-family: 'Frank Ruhl Libre', serif; font-size: 11px; font-weight: 700;
    color: var(--yellow); margin-bottom: 16px;
    letter-spacing: 0.15em; text-transform: uppercase;
    transition: color 0.3s;
    position: relative; z-index: 1;
  }
  .service-title {
    font-family: 'Frank Ruhl Libre', serif; font-weight: 700;
    font-size: 19px;
    text-transform: uppercase;
    line-height: 1.15;
    margin-bottom: auto;
    padding-bottom: 20px;
    position: relative; z-index: 1;
  }
  .service-price {
    align-self: flex-start;
    font-family: 'Frank Ruhl Libre', serif; font-size: 15px;
    font-weight: 700; color: var(--yellow);
    background: rgba(255,212,0,0.1);
    padding: 8px 14px;
    border: 1px solid rgba(255,212,0,0.25);
    position: relative; z-index: 1;
    transition: background 0.3s, border-color 0.3s;
  }
  .service-card:hover .service-price {
    background: var(--yellow); color: var(--black);
    border-color: var(--yellow);
    animation: priceBlink 0.6s ease;
  }
  @keyframes priceBlink {
    0%, 100% { opacity: 1; }
    30% { opacity: 0.3; }
    60% { opacity: 1; }
    80% { opacity: 0.5; }
  }
  .service-note {
    font-size: 12px;
    color: rgba(247,245,240,0.45);
    margin-top: 6px;
    position: relative; z-index: 1;
    line-height: 1.4;
  }

  /* ---------- WHY US ---------- */
  .why {
    background: var(--yellow); color: var(--black); position: relative;
  }
  .why::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 12px;
    background: repeating-linear-gradient(90deg, var(--black) 0 40px, var(--yellow) 40px 80px);
  }
  .why::after {
    content: ""; position: absolute; bottom: 0; left: 0; right: 0; height: 12px;
    background: repeating-linear-gradient(90deg, var(--black) 0 40px, var(--yellow) 40px 80px);
  }
  .why .section-label { color: var(--black); }
  .why .section-label::before { background: var(--black); }
  .why-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px; margin-top: 60px;
  }
  .why-item {
    background: var(--black); color: var(--white); padding: 36px 28px;
    border: 3px solid var(--black); position: relative;
    transition: transform 0.2s;
  }
  .why-item:nth-child(2n) { transform: rotate(-1deg); }
  .why-item:nth-child(3n) { transform: rotate(1deg); }
  .why-item:hover { transform: translateY(-8px) rotate(0); }
  .why-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900; font-size: 56px; line-height: 1;
    color: var(--yellow); margin-bottom: 12px;
  }
  .why-text { font-weight: 700; font-size: 16px; text-transform: uppercase; letter-spacing: 0.02em; }

  /* ---------- CASES ---------- */
  .cases { background: var(--black); }
  .cases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .case-card {
    background: var(--grey-2);
    border: 2px solid var(--grey);
    padding: 32px 28px;
    position: relative;
    transition: all 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .case-card::before {
    content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
    background: var(--yellow);
  }
  .case-card:hover { border-color: var(--yellow); transform: translateY(-6px); }
  .case-tag {
    display: inline-block;
    align-self: flex-start;
    background: var(--yellow); color: var(--black);
    padding: 5px 12px;
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 20px;
  }
  .case-quote {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: 20px;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0;
    margin-bottom: auto;
    padding-bottom: 20px;
  }
  .case-result {
    border-top: 1px dashed rgba(255,212,0,0.3);
    padding-top: 16px;
    font-size: 13px;
    color: rgba(247,245,240,0.6);
    line-height: 1.6;
  }
  .case-result strong {
    color: var(--yellow);
    display: block;
    font-size: 16px;
    margin-bottom: 6px;
    font-family: 'Frank Ruhl Libre', serif; font-weight: 700;
    letter-spacing: 0.01em;
  }

  /* ---------- HOW ---------- */
  .how { background: var(--ink); }
  .how-steps {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 0;
    border: 2px solid var(--yellow);
  }
  .step {
    padding: 40px 24px; border-right: 2px solid var(--yellow);
    position: relative;
  }
  .step:last-child { border-right: none; }
  .step-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900; font-size: 64px; line-height: 0.8;
    color: var(--yellow); margin-bottom: 20px; display: block;
  }
  .step-title {
    font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 16px;
    text-transform: uppercase; margin-bottom: 12px;
  }
  .step-desc { font-size: 13px; color: rgba(247,245,240,0.65); line-height: 1.5; }

  /* ---------- BIG CTA ---------- */
  .big-cta { background: var(--yellow); padding: 110px 0; position: relative; overflow: hidden; }
  .big-cta::before {
    content: "URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT";
    position: absolute; top: 20px; left: -10%; right: -10%;
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 80px; line-height: 1; opacity: 0.07; white-space: nowrap;
    color: var(--black);
  }
  .big-cta::after {
    content: "URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT URGENT";
    position: absolute; bottom: 20px; left: -10%; right: -10%;
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 80px; line-height: 1; opacity: 0.07; white-space: nowrap;
    color: var(--black);
  }
  .big-cta-content { position: relative; z-index: 2; text-align: center; }
  .big-cta h2 {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(40px, 5.5vw, 84px);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--black);
    margin-bottom: 24px;
  }
  .big-cta h2 .yellow {
    color: var(--black);
    
  }
  .big-cta p { font-size: 20px; color: rgba(10,10,10,0.75); margin-bottom: 40px; }
  .big-cta .cta-row { justify-content: center; }
  /* On yellow bg use white buttons */
  .big-cta .btn-primary { background: var(--black); color: var(--yellow); }
  .big-cta .btn-secondary { background: var(--white); color: var(--black); }

  /* ---------- CONTACTS ---------- */
  .contacts { background: var(--black); padding: 110px 0; }
  .contacts-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 60px; align-items: start; }
  .contact-card {
    display: flex; align-items: center; gap: 20px;
    padding: 24px; background: var(--ink); border: 2px solid var(--grey);
    margin-bottom: 16px; text-decoration: none; color: var(--white);
    transition: all 0.2s;
  }
  .contact-card:hover { border-color: var(--yellow); transform: translateX(8px); }
  .contact-icon {
    width: 56px; height: 56px; flex-shrink: 0;
    background: var(--yellow); color: var(--black);
    display: grid; place-items: center;
  }
  .contact-icon svg { width: 28px; height: 28px; }
  .contact-label { font-family: 'Frank Ruhl Libre', serif; font-size: 11px; text-transform: uppercase; color: rgba(247,245,240,0.5); margin-bottom: 4px; }
  .contact-value { font-family: 'Frank Ruhl Libre', serif; font-weight: 700; font-size: 20px; }

  footer {
    border-top: 1px solid var(--grey); padding: 40px 0;
    text-align: center; font-family: 'Frank Ruhl Libre', serif;
    font-size: 12px; color: rgba(247,245,240,0.4); text-transform: uppercase;
  }

  /* ---------- LANG SWITCHER ---------- */
  .lang-switcher {
    display: flex; gap: 0;
    background: var(--ink); border: 2px solid var(--grey);
    overflow: hidden;
  }
  .lang-btn {
    background: none; border: none; cursor: pointer;
    padding: 8px 14px;
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 11px; font-weight: 700; color: rgba(247,245,240,0.6);
    text-transform: uppercase; letter-spacing: 0.1em;
    transition: all 0.2s;
  }
  .lang-btn:hover { color: var(--white); }
  .lang-btn.active {
    background: var(--yellow); color: var(--black);
  }

  /* ---------- DISCLAIMER ---------- */
  .disclaimer-section {
    background: var(--bg, var(--black));
    padding: 40px 0 20px;
    border-top: 1px solid var(--grey);
  }
  .disclaimer-box {
    max-width: 900px; margin: 0 auto;
    border: 1px solid var(--grey);
    background: var(--ink);
  }
  .disclaimer-toggle {
    width: 100%;
    background: none; border: none; cursor: pointer;
    padding: 18px 24px;
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    text-align: left;
    color: var(--white);
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    transition: color 0.2s;
  }
  .disclaimer-toggle:hover { color: var(--yellow); }
  .disclaimer-toggle .label { display: flex; align-items: center; gap: 12px; }
  .disclaimer-toggle .label::before {
    content: "§"; color: var(--yellow); font-size: 18px;
    font-family: 'Frank Ruhl Libre', serif;
  }
  .disclaimer-toggle .icon {
    flex-shrink: 0;
    width: 22px; height: 22px;
    border: 1.5px solid var(--yellow); color: var(--yellow);
    display: grid; place-items: center;
    font-family: 'Frank Ruhl Libre', serif; font-size: 14px;
    transition: transform 0.3s;
  }
  .disclaimer-box.open .disclaimer-toggle .icon { transform: rotate(45deg); }
  .disclaimer-content {
