<script>
  // ---------- TRUCK INTRO ANIMATION ----------
  (function() {
    var intro = document.getElementById('truckIntro');
    var truck = document.getElementById('truckGroup');
    var heroLogo = document.querySelector('.hero-logo img');
    var fadeUps = document.querySelectorAll('.hero .fade-up');
    var startTime = null;
    var phase = 'driving-in';

    function moveTruck(x) {
      truck.style.transform = 'translateX(calc(-50% + ' + x + 'px))';
    }
    function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
    function easeInCubic(t) { return t * t * t; }

    // Timeline: 0-1200 drive in, 1200-2200 idle, 2200-3200 drive out, 3200-3800 fade, 3800+ hero
    function animate(ts) {
      if (!startTime) startTime = ts;
      var elapsed = ts - startTime;

      if (phase === 'driving-in') {
        var t = Math.min(elapsed / 1200, 1);
        moveTruck(-window.innerWidth * 0.8 + window.innerWidth * 0.8 * easeOutCubic(t));
        if (t >= 1) { phase = 'idle'; truck.classList.add('idle'); }
      }
      else if (phase === 'idle') {
        if (elapsed > 2200) { phase = 'driving-away'; truck.classList.remove('idle'); }
      }
      else if (phase === 'driving-away') {
        var t = Math.min((elapsed - 2200) / 1000, 1);
        moveTruck(window.innerWidth * 0.9 * easeInCubic(t));
        if (t >= 1) { phase = 'fadeout'; intro.classList.add('done'); }
      }
      else if (phase === 'fadeout') {
        if (elapsed > 3800) {
          heroLogo.classList.add('stamp');
          setTimeout(function() {
            fadeUps.forEach(function(el) { el.classList.add('go'); });
          }, 300);
          return;
        }
      }
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  })();
</script>

